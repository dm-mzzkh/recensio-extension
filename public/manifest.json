{
  "manifest_version": 3,
  "name": "Recensio",
  "version": "0.1.0",
  "description": "Save YouTube videos with tags, ratings, and reviews",
  "browser_specific_settings": {
    "gecko": {
      "id": "recensio@local",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Recensio"
  },
  "background": {
    "scripts": ["background/index.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content/index.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["editor/index.html", "editor/main.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "icons": {
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
